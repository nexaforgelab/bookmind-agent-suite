# BookMind Configuration
# ============================================
# 复制此文件为 .env 并根据需要修改配置
# Copy this file to .env and customize as needed

# ===== Core Settings =====
BOOKMIND_DATA_DIR=./data
BOOKMIND_OUTPUT_DIR=./output
BOOKMIND_LOG_LEVEL=INFO

# ===== PDF Processing =====
PDF_DPI=300
PDF_MAX_SIZE_MB=500
PDF_PAGE_LIMIT=2000

# ===== OCR Settings (Optional) =====
# OCR_LANGUAGE=chi_sim+eng  # For Chinese-English mixed PDFs
# OCR_ENGINE=tesseract  # tesseract or paddleocr

# ===== Vector Search (Optional) =====
# VECTOR_ENGINE=faiss
# VECTOR_DIMENSION=768
# CHUNK_SIZE=512
# CHUNK_OVERLAP=50

# ===== Export Settings =====
EXPORT_FORMATS=markdown,html,json
EXPORT_OUTPUT_DIR=./exports

# ===== Skill Runtime =====
SKILLS_DIR=./skills
SKILL_TIMEOUT_SECONDS=300
SKILL_PARALLEL_WORKERS=4

# ===== Security =====
ALLOWED_PATHS=./data,./examples
SANDBOX_ENABLED=true

# ===== API Keys (if using LLM services) =====
# OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
